{
  "name": "@getcorespec/bot",
  "version": "0.0.1",
  "private": true,
  "description": "GitHub App webhook server for corespec tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/getcorespec/corespec",
    "directory": "packages/bot"
  },
  "license": "MIT",
  "author": "getcorespec",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@getcorespec/specguard": "workspace:*",
    "@hono/node-server": "^1.14.1",
    "@octokit/app": "^15.1.2",
    "@octokit/core": "^6.1.4",
    "@octokit/webhooks": "^13.6.1",
    "dotenv": "^17.3.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
